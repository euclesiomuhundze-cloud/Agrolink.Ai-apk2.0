<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_match"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Título do App -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AgroLink"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="32dp" />

    <!-- Descrição de como usar -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tire uma foto de uma planta ou folha para identificar pragas e doenças com Inteligência Artificial."
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="#555555"
        android:layout_marginBottom="48dp" />

    <!-- Botão para tirar a foto (ID importante para a MainActivity.kt) -->
    <Button
        android:id="@+id/btnCapturar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Tirar Foto da Planta"
        android:textSize="18sp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Campo que mostrará o diagnóstico (ID importante para a MainActivity.kt) -->
    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="O diagnóstico aparecerá aqui..."
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="#333333"
        android:padding="16dp" />

</LinearLayout>

